if SHIELD_SWEEP_LEFT
# Name must be less than 16 characters long!
config ZMK_KEYBOARD_NAME
    default "Sweep Pro"

config ZMK_SPLIT_ROLE_CENTRAL
    default y

endif 


if SHIELD_SWEEP_DONGLE_LEFT
config ZMK_KEYBOARD_NAME
    default "Sweep Pro"

config ZMK_SPLIT_ROLE_CENTRAL
    default n

endif

if SHIELD_SWEEP_LEFT || SHIELD_SWEEP_RIGHT || SHIELD_SWEEP_DONGLE_LEFT
config ZMK_SPLIT
    default y
endif
